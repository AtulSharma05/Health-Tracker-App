{
  "name": "nutripal-backend",
  "version": "1.0.0",
  "description": "NutriPal backend with Node, Express, MongoDB",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test:smoke": "node src/scripts/smokeTest.js",
    "migrate:dry": "node src/scripts/migrateData.js --dry-run",
    "migrate:run": "node src/scripts/migrateData.js",
    "seed:foods": "node src/scripts/seedFoods.js"
  },
  "dependencies": {
    "axios": "^1.16.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.8.3",
    "nodemailer": "^6.9.7"
  },
  "devDependencies": {
    "nodemon": "^3.1.7"
  }
}
