# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/nutripal_db

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Email Service (Gmail SMTP example)
EMAIL_SERVICE=gmail
EMAIL_USER=your_google_email@gmail.com
EMAIL_PASSWORD=your_app_specific_password
# Note: For Gmail, use App Password (not your regular password)
# Enable 2FA and generate at: https://myaccount.google.com/apppasswords

# Frontend URL (for email verification and password reset links)
FRONTEND_URL=http://localhost:3000

# Google OAuth (optional)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Server
PORT=4000
NODE_ENV=development

# Integration modules (workout + AI planner + pose)
AI_PLANNER_URL=http://localhost:8000
AI_PLANNER_PORT=8000
AI_PLANNER_TIMEOUT_MS=30000
AI_PYTHON_PATH=python
AI_API_SERVER_PATH=./ai-planner/api_server.py
EXERCISES_DB_PATH=./ai-planner/data/exercises.json

POSE_API_URL=http://localhost:8001
POSE_EXERCISE_MAPPING_PATH=./pose-corrector/data/exercise_id_mapping.json

# Google Gemini AI (Food Image Analysis — primary + secondary)
# Get your free API key at: https://aistudio.google.com/app/apikey
# Fallback order: Gemini 2.5 Flash → Gemini 2.5 Flash-Lite → OpenRouter
GEMINI_API_KEY=your_gemini_api_key_here

# OpenRouter AI (Food Image Analysis — last-resort fallback)
# Get your free API key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
